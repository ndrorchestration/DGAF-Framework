  "objective": "Improve governance_clear routing accuracy from 82.6% to >=95% by replacing regex-only detection with logistic regression TF-IDF classifier and adding governance-specific confidence sub-bands",
  "v3_5_baseline": {
    "overall_accuracy": 0.95,
    "adversarial": 1.0,
    "ambiguous": 0.947,
    "governance_clear": 0.826,
    "creative_clear": 1.0,
