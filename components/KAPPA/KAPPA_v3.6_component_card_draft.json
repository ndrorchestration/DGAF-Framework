  "v3_6_targets": {
    "overall_accuracy": ">=0.95",
    "adversarial": "1.0 (hard floor)",
    "ambiguous": ">=0.90",
    "governance_clear": ">=0.95",
    "creative_clear": ">=0.90",
    "unclear": "1.0 (hard floor)"
  },
  "changes": {
    "classifier_upgrade": {
      "from": "regex_only",
      "to": "logistic_regression_tfidf",
      "model": "sklearn.linear_model.LogisticRegression",
      "features": "TfidfVectorizer(ngram_range=(1,3), max_features=5000, sublinear_tf=True)",
      "hyperparams": {"C": 1.0, "class_weight": "balanced", "max_iter": 1000, "random_state": 42}
    },
    "confidence_bands": {
      "governance_strong": "p_governance_clear >= 0.45 AND intent == directive",
      "governance_blended": "p_governance_clear 0.25-0.45 OR intent == discretionary",
      "apply_strong": "score >= 0.28 (non-governance, unchanged)",
      "apply_blended": "score 0.15-0.28 (non-governance, unchanged)",
      "apply_light": "score < 0.15 (unchanged)"
    },
    "intent_classifier": {
      "directive_signals": ["must", "shall", "required", "mandatory", "enforce"],
      "discretionary_signals": ["should", "consider", "recommended", "may", "if appropriate"],
      "default": "governance_blended"
    }
  },
  "validation_plan": {
    "total_passes": 100,
    "governance_clear_items": 23,
    "governance_clear_pass_threshold": 22,
    "regression_guard": {
