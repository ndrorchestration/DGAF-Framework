{
  "manifest_version": "v16",
  "anchor": "S043",
  "last_updated": "2026-05-29",
  "owner": "Ender",
  "steward": "COLLEEN",
  "orchestrator": "Amethyst",
  "description": "Full ensemble manifest for DGAF-Framework v16. Includes all 9 turn-sequence gate bindings, SCPE config, Phi-Closure gate, HPG, orchestration firewall, and topology router. Supersedes v14.",
  "supersedes": "ensemble_v14_manifest.json",
  "turn_sequence": [
    {
      "step": 1,
      "name": "SCPE.prune",
      "component": "components/scpe_ensemble_v14.py",
      "pattern": "NDR-005",
      "config": {
        "threshold": 0.15,
        "axiom_tier": "T0",
        "structural_tier": "T1",
        "operational_tier": "T2",
        "exploratory_tier": "T3",
        "t0_immune": true,
        "last_3_t2_anchor": true,
        "psi_cubic_check_tolerance": 1e-12
      },
      "emits": ["PruneEvent"],
      "audit_target": "AmethystAuditLoop.prune_log"
    },
    {
      "step": 2,
      "name": "COLLEEN.schema_diff_check",
      "component": "components/colleen_schema_diff.py",
      "pattern": "NDR-002",
      "config": {
        "hash_algorithm": "SHA-256",
        "ssot_reference": "registry/state_ssot.json"
      },
      "emits": ["SchemaDiffEvent"]
    },
    {
      "step": 3,
      "name": "RECIPROCITY.arbitrate",
      "component": "components/reciprocity_arbiter.py",
      "pattern": "NDR-004",
      "config": {
        "trigger": "on_alert",
        "pdmal_reweight": true,
        "apogee_floater": true,
        "colleen_ratify": true
      },
      "emits": ["ArbitrationEvent"]
    },
    {
      "step": 4,
      "name": "DEMIJOUL.safety_gate",
      "component": "components/dgaf_semantic_gate.py",
      "pattern": "NDR-010",
      "config": {
        "layer_1": "syntactic_blocked_patterns",
        "layer_2": "dgaf_6axis_semantic_scoring",
        "decisions": ["KILL", "REPROMPT", "pass"],
        "early_return_on_kill": true,
        "records_stable_for_phi_gate": true
      },
      "emits": ["SafetyGateEvent"]
    },
    {
      "step": 5,
      "name": "PHI_CLOSURE_GATE",
      "component": "components/phi_closure_gate.py",
      "pattern": "NDR-006",
      "config": {
        "target_phi_conjugate": 0.6180339887,
        "tolerance": 0.05,
        "fibonacci_checkpoints": [13, 21, 34, 55],
        "pass_action": "continue_to_hpg",
        "fail_action": "reprompt_skip_hpg_early_seal",
        "consecutive_fail_threshold": 2,
        "consecutive_fail_action": "kill_recommendation_to_demijoul"
      },
      "emits": ["PhiClosureEvent"]
    },
    {
      "step": 6,
      "name": "HPG.gate",
      "component": "components/hpg_ionian_gate.py",
      "pattern": "NDR-007",
      "config": {
        "octave_range": [1, 2],
        "membership_mode": "Phi-Ionian",
        "snap_nearest": true,
        "tolerance": 1e-9,
        "condition": "only_if_phi_closure_pass"
      },
      "emits": ["HPGGateEvent"]
    },
    {
      "step": 7,
      "name": "PRODIGY.verify",
      "component": "components/prodigy_verifier.py",
      "pattern": "NDR-003",
      "config": {
        "mandatory_threshold": 0.85,
        "below_threshold_action": "mandatory_verify",
        "above_threshold_action": "advisory"
      },
      "emits": ["ProdigyVerifyEvent"]
    },
    {
      "step": 8,
      "name": "APOGEE.review_artifact_seal",
      "component": "components/amethyst_dual_lock.py",
      "pattern": "NDR-011",
      "config": {
        "evidence_grades": ["A", "B", "C"],
        "qa_tiers": ["Gold", "Silver", "Bronze"],
        "gold_star_gate": true,
        "apogee_lens_required_for_s_tier": true
      },
      "emits": ["ApogeeReviewEvent"]
    },
    {
      "step": 9,
      "name": "AMETHYST.seal",
      "component": "components/orchestration_firewall.py",
      "pattern": "NDR-008",
      "config": {
        "hash_algorithm": "SHA-256",
        "log_target": "amethyst_audit.json",
        "append_only": true,
        "includes_prune_events": true,
        "includes_phi_closure_events": true,
        "includes_gate_events": true
      },
      "emits": ["TurnAuditRecord"]
    }
  ],
  "orchestration_firewall": {
    "invariants": [
      "no_unreviewed_deploy",
      "tests_before_deploy",
      "single_active_deploy_attempt",
      "provenance_complete",
      "authority_bounded_deployment"
    ],
    "rollback_on_violation": true,
    "audit_all_events": true
  },
  "state_anchor_goals": {
    "zero_open_blg": true,
    "single_authority_chain": true,
    "append_only_log": true,
    "observable_invariants_only": true,
    "procluding_premise_first": true
  },
  "integrations": {
    "langchain": "SCPECallbackHandler in scpe_ensemble_v14.py",
    "langgraph": "scpe_node inserted before router_node",
    "autogen": "SCPEAgent wraps ConversableAgent",
    "crewai": "scpe_kickoff_wrapper pre-processes inputs"
  },
  "changelog": [
    {"version": "v16", "date": "2026-05-29", "changes": "Added Phi-Closure gate (step 5), orchestration firewall invariants, full 9-step turn sequence manifest, S043 state anchors"},
    {"version": "v14", "date": "2026-05-28", "changes": "Added SCPE threshold lock at 0.15, framework adapters (LangChain/LangGraph/AutoGen/CrewAI)"},
    {"version": "v12", "date": "2026-05-21", "changes": "HPG Ionian gate, DGAF 6-axis semantic scoring"}
  ]
}
